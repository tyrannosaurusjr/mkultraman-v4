---
import SchemaOrg from '../components/SchemaOrg.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  pubDate?: string;
  noindex?: boolean;
}

const {
  title = 'MKUltraman — Digital Infrastructure for SMEs in Japan',
  description = 'Your tech stack is costing you money. I audit, fix, and manage the digital infrastructure SMEs run on. Based in Tokyo.',
  ogImage = '/images/og-default.png',
  article = false,
  pubDate,
  noindex = false,
} = Astro.props;

const siteURL = (Astro.site ?? 'https://mkultraman.com').toString().replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL = new URL(ogImage, siteURL);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="MKUltraman" />
    <meta property="og:locale" content="en_US" />
    {article && pubDate && <meta property="article:published_time" content={pubDate} />}
    {article && <meta property="article:author" content="Matt Ketchum (MKUltraman)" />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:site" content="@mkultraman" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,400&family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Global styles -->
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Structured Data -->
    <SchemaOrg />
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
