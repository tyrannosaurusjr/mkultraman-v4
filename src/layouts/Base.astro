---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  pubDate?: string;
  noindex?: boolean;
}

const {
  title = 'MKUltraman — Digital Infrastructure for SMEs in Japan',
  description = 'Your tech stack is costing you money. I audit, fix, and manage the digital infrastructure SMEs run on. Based in Tokyo.',
  ogImage = '/images/tetsu-island.webp',
  article = false,
  pubDate,
  noindex = false,
} = Astro.props;

const siteURL = (Astro.site ?? 'https://mkultraman.com').toString().replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL = new URL(ogImage, siteURL);

const isHome = Astro.url.pathname === '/';

const orgSchema = {
  "@type": "Organization",
  "@id": `${siteURL}/#organization`,
  "name": "MKUltraman",
  "url": siteURL.toString(),
  "logo": new URL('/favicon.svg', siteURL).toString(),
  "description": "Digital infrastructure management for SMEs in Japan.",
  "founder": {
    "@type": "Person",
    "name": "Matt Ketchum",
    "jobTitle": "Digital Infrastructure Consultant",
    "url": siteURL.toString(),
  },
  "areaServed": { "@type": "Country", "name": "Japan" },
  "sameAs": ["https://instagram.com/mkultraman"],
};

const websiteSchema = {
  "@type": "WebSite",
  "@id": `${siteURL}/#website`,
  "name": "MKUltraman",
  "url": siteURL.toString(),
  "publisher": { "@id": `${siteURL}/#organization` },
};

const homeSchemaGraph = [orgSchema, websiteSchema];

const articleSchema = article ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalURL.toString(),
  "image": ogImageURL.toString(),
  "datePublished": pubDate,
  "author": { "@type": "Person", "name": "Matt Ketchum", "url": siteURL.toString() },
  "publisher": { "@id": `${siteURL}/#organization` },
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="MKUltraman" />
    {article && pubDate && <meta property="article:published_time" content={pubDate} />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:site" content="@mkultraman" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,400&family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Global styles -->
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Analytics -->
    <script defer data-domain="mkultraman.com" src="https://plausible.io/js/script.js"></script>

    <!-- Structured Data -->
    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": homeSchemaGraph })} />
    )}
    {articleSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
