---
const sectors = [
  "Community & Events",
  "Construction",
  "Professional Services",
  "IT & Technology",
  "Coaching",
  "Entertainment",
  "Networks",
  "Media",
];

const outcomes = [
  { stat: "¥6.5M", label: "annual revenue increase for a community client after payment and membership integration" },
  { stat: "120×", label: "traffic growth for a construction firm — from under 5 to 600+ daily visitors" },
  { stat: "3+", label: "qualified leads added per month via Reddit outreach automation" },
];

const cases = [
  {
    industry: "Community organization · Tokyo",
    result: "¥6.5M revenue increase",
    before: "Collecting payment by bank transfer, running events off a broken website, emailing a messy list with account details and hoping people paid in advance. Cash at the door for the rest.",
    after: "Integrated Stripe payments, Luma event management, and membership tracking into a single system. Revenue became visible and predictable for the first time.",
  },
  {
    industry: "Construction · Japan",
    result: "600+ daily visitors, 7 qualified inquiries/month",
    before: "Under 5 visitors per day. Bloated images, thin content, orphaned pages, off-putting copy, and a generic domain that signaled nothing about the business.",
    after: "Full rebuild with hub-and-spoke content architecture, optimized media, automated contact system, and a premium industry domain secured. Top Google placement within 6 months.",
  },
  {
    industry: "SME operator · ongoing",
    result: "3+ converting leads/month from Reddit",
    before: "No systematic way to reach the communities where qualified buyers were already asking relevant questions.",
    after: "RedditReach monitors target subreddits for relevant posts and surfaces reply opportunities. The client schedules contextual responses and converts Reddit traffic into paying customers.",
  },
];
---

<section class="proof">
  <div class="container">
    <div class="proof-inner">
      <div class="proof-outcomes">
        {outcomes.map(o => (
          <div class="outcome">
            <span class="outcome-stat">{o.stat}</span>
            <span class="outcome-label">{o.label}</span>
          </div>
        ))}
      </div>

      <div class="proof-divider"></div>

      <div class="proof-testimonials">
        <p class="testimonials-label">Client results</p>
        <div class="testimonial-grid">
          {cases.map(c => (
            <div class="testimonial">
              <div class="testimonial__header">
                <span class="testimonial__result">{c.result}</span>
                <span class="testimonial__industry">{c.industry}</span>
              </div>
              <div class="testimonial__body">
                <p class="testimonial__before"><strong>Before:</strong> {c.before}</p>
                <p class="testimonial__after"><strong>After:</strong> {c.after}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="proof-divider"></div>

      <div class="proof-sectors">
        <p class="sectors-label">Industries served</p>
        <div class="sector-list">
          {sectors.map(s => (
            <span class="sector-tag">{s}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .proof {
    padding: var(--space-64) 0;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .proof-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-48);
  }

  /* Outcomes row */
  .proof-outcomes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
  }

  .outcome {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .outcome-stat {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 900;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .outcome-label {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
    max-width: 200px;
  }

  .proof-divider {
    height: 1px;
    background: var(--border);
  }

  /* Sectors row */
  .sectors-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: var(--space-16);
  }

  .sector-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }

  .sector-tag {
    font-size: 13px;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 5px 12px;
    border-radius: var(--radius-full);
  }

  /* Testimonials */
  .testimonials-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: var(--space-24);
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-24);
  }

  .testimonial {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .testimonial__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--border);
  }

  .testimonial__result {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .testimonial__industry {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .testimonial__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .testimonial__before,
  .testimonial__after {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .testimonial__before strong,
  .testimonial__after strong {
    color: var(--text-dim);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .testimonial-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .proof-outcomes {
      grid-template-columns: 1fr 1fr;
    }
    .proof-outcomes .outcome:last-child {
      grid-column: 1 / -1;
    }
  }
</style>
