---
const sectors = [
  "Food & Beverage",
  "Professional Services",
  "Media & Publishing",
  "Real Estate",
  "Retail",
  "Healthcare",
  "Education",
  "Logistics",
];

const outcomes = [
  { stat: "¥2–8M", label: "typical annual tool spend recovered per audit" },
  { stat: "60 days", label: "average time from audit to working replacement system" },
  { stat: "30%+", label: "typical reduction in operational overhead" },
];

const testimonials = [
  {
    quote: "We were paying for 14 different tools and using maybe half the features on three of them. The audit paid for itself in the first month.",
    role: "Operations Director",
    industry: "F&B group, Tokyo",
  },
  {
    quote: "He rebuilt our entire project management stack in six weeks. The team actually uses it now — that's the difference.",
    role: "CEO",
    industry: "Media company, Osaka",
  },
  {
    quote: "Having someone who understands both the Japan side and the tech side is rare. We stopped burning money on tools that don't talk to each other.",
    role: "Managing Partner",
    industry: "Professional services, Tokyo",
  },
];
---

<section class="proof">
  <div class="container">
    <div class="proof-inner">
      <div class="proof-outcomes">
        {outcomes.map(o => (
          <div class="outcome">
            <span class="outcome-stat">{o.stat}</span>
            <span class="outcome-label">{o.label}</span>
          </div>
        ))}
      </div>

      <div class="proof-divider"></div>

      <div class="proof-testimonials">
        <p class="testimonials-label">What clients say</p>
        <div class="testimonial-grid">
          {testimonials.map(t => (
            <blockquote class="testimonial">
              <p class="testimonial__quote">"{t.quote}"</p>
              <footer class="testimonial__source">
                <span class="testimonial__role">{t.role}</span>
                <span class="testimonial__industry">{t.industry}</span>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>

      <div class="proof-divider"></div>

      <div class="proof-sectors">
        <p class="sectors-label">Industries served</p>
        <div class="sector-list">
          {sectors.map(s => (
            <span class="sector-tag">{s}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .proof {
    padding: var(--space-64) 0;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .proof-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-48);
  }

  /* Outcomes row */
  .proof-outcomes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
  }

  .outcome {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .outcome-stat {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 900;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .outcome-label {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
    max-width: 200px;
  }

  .proof-divider {
    height: 1px;
    background: var(--border);
  }

  /* Sectors row */
  .sectors-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: var(--space-16);
  }

  .sector-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }

  .sector-tag {
    font-size: 13px;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 5px 12px;
    border-radius: var(--radius-full);
  }

  /* Testimonials */
  .testimonials-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: var(--space-24);
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-24);
  }

  .testimonial {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .testimonial__quote {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
    font-style: italic;
    flex: 1;
  }

  .testimonial__source {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: var(--space-12);
    border-top: 1px solid var(--border);
  }

  .testimonial__role {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
  }

  .testimonial__industry {
    font-size: 12px;
    color: var(--text-dim);
  }

  @media (max-width: 768px) {
    .testimonial-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .proof-outcomes {
      grid-template-columns: 1fr 1fr;
    }
    .proof-outcomes .outcome:last-child {
      grid-column: 1 / -1;
    }
  }
</style>
