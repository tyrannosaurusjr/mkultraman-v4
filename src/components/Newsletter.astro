---
interface Props {
  variant?: 'section' | 'footer';
}

const { variant = 'section' } = Astro.props;
const SUBSTACK_URL = 'https://mkultraman.substack.com/subscribe';
const FORMSPREE_ID = "mbdppqqq";
---

{variant === 'section' && (
  <section class="newsletter">
    <div class="container">
      <div class="newsletter__inner">
        <div class="newsletter__content">
          <p class="eyebrow">Newsletter</p>
          <h2 class="newsletter__heading">The Japan Operator Briefing</h2>
          <p class="newsletter__sub">
            What I'm watching in Japan: infrastructure, strategy, and market
            dynamics. One email when I publish. No spam, no sequences.
          </p>
        </div>
        <div class="newsletter__form">
          <form
            id="newsletter-form"
            action={`https://formspree.io/f/${FORMSPREE_ID}`}
            method="POST"
            class="newsletter__capture"
          >
            <input type="hidden" name="_subject" value="Newsletter signup" />
            <input type="hidden" name="type" value="newsletter" />
            <div class="newsletter__row">
              <input
                class="newsletter__input"
                id="newsletter-email"
                name="email"
                type="email"
                placeholder="your@email.com"
                required
                aria-label="Email address"
              />
              <button type="submit" class="btn btn-primary newsletter__btn" id="newsletter-submit">
                Subscribe &rarr;
              </button>
            </div>
            <p class="newsletter__success hidden" id="newsletter-success">✓ Subscribed. First issue is on its way.</p>
            <p class="newsletter__error hidden" id="newsletter-error">Something went wrong. Try <a href={SUBSTACK_URL} target="_blank" rel="noopener noreferrer">Substack directly</a>.</p>
          </form>
          <p class="newsletter__note">Japan operators only. Free. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'footer' && (
  <div class="newsletter-footer">
    <p class="newsletter-footer__label">Get the briefing</p>
    <a href={SUBSTACK_URL} target="_blank" rel="noopener noreferrer" class="newsletter-footer__link">
      Subscribe on Substack &rarr;
    </a>
  </div>
)}

<style>
  /* ── Section variant ── */
  .newsletter {
    padding: var(--space-64) 0;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .newsletter__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-64);
    align-items: center;
  }
  .newsletter__heading {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 900;
    color: var(--text);
    letter-spacing: -0.02em;
    margin: var(--space-16) 0 var(--space-12);
  }
  .newsletter__sub {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 420px;
  }
  .newsletter__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  .newsletter__capture {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .newsletter__row {
    display: flex;
    gap: var(--space-8);
  }
  .newsletter__input {
    flex: 1;
    height: 42px;
    padding: 0 var(--space-12);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 14px;
    color: var(--text);
    font-family: var(--font-body, sans-serif);
    transition: border-color 0.15s;
    min-width: 0;
  }
  .newsletter__input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .newsletter__input::placeholder { color: var(--text-dim); }
  .newsletter__btn {
    white-space: nowrap;
    flex-shrink: 0;
  }
  .newsletter__success {
    font-size: 13px;
    color: var(--success, #4ade80);
    font-weight: 500;
  }
  .newsletter__error {
    font-size: 12px;
    color: var(--accent);
  }
  .newsletter__error a { color: var(--accent); text-decoration: underline; }
  .newsletter__note {
    font-size: 12px;
    color: var(--text-dim);
  }
  .hidden { display: none; }

  /* ── Footer variant ── */
  .newsletter-footer {
    margin-top: var(--space-16);
  }
  .newsletter-footer__label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }
  .newsletter-footer__link {
    font-size: 14px;
    color: var(--text-dim);
    transition: color 0.15s;
  }
  .newsletter-footer__link:hover { color: var(--text); }

  @media (max-width: 768px) {
    .newsletter__inner {
      grid-template-columns: 1fr;
      gap: var(--space-32);
    }
    .newsletter__row {
      flex-direction: column;
    }
  }
</style>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const btn = document.getElementById('newsletter-submit') as HTMLButtonElement;
  const success = document.getElementById('newsletter-success') as HTMLElement;
  const error = document.getElementById('newsletter-error') as HTMLElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.textContent = 'Subscribing…';
      btn.disabled = true;

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.reset();
          btn.classList.add('hidden');
          success.classList.remove('hidden');
        } else {
          throw new Error('non-ok');
        }
      } catch {
        btn.textContent = 'Subscribe →';
        btn.disabled = false;
        error.classList.remove('hidden');
      }
    });
  }
</script>
