---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4)
  .map(post => ({
    title: post.data.title,
    excerpt: post.data.description,
    tags: post.data.tags,
    href: `/blog/${post.id}/`,
    external: false,
  }));
---

<section class="insights">
  <div class="container">
    <div class="insights__header">
      <div>
        <p class="eyebrow">Field notes</p>
        <h2 class="insights__headline">What I'm watching in Japan.</h2>
      </div>
      <a href="/blog" class="insights__all">
        All articles →
      </a>
    </div>

    <div class="insights__grid">
      {posts.map((post) => (
        <a
          href={post.href}
          target={post.external ? '_blank' : undefined}
          rel={post.external ? 'noopener' : undefined}
          class="post-card"
        >
          <div class="post-card__tags">
            {post.tags.map(tag => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
          <h3 class="post-card__title">{post.title}</h3>
          <p class="post-card__excerpt">{post.excerpt}</p>
          <span class="post-card__read">Read →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .insights {
    padding: var(--space-96) 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .insights__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: var(--space-48);
    gap: var(--space-24);
  }

  .insights__headline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-top: var(--space-16);
  }

  .insights__all {
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.15s;
    padding-bottom: 4px;
  }
  .insights__all:hover { opacity: 0.75; }

  .insights__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-24);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding: var(--space-32);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.2s ease;
    text-decoration: none;
  }
  .post-card:hover { border-color: var(--accent); }

  .post-card__tags {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: var(--radius-full);
  }

  .post-card__title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
  }

  .post-card__excerpt {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
  }

  .post-card__read {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    align-self: flex-start;
    margin-top: var(--space-8);
  }

  @media (max-width: 768px) {
    .insights__grid { grid-template-columns: 1fr; }
    .insights__header { flex-direction: column; align-items: flex-start; }
  }
</style>
