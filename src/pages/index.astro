---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problems from '../components/Problems.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import About from '../components/About.astro';
import Proof from '../components/Proof.astro';
import ToolsShowcase from '../components/ToolsShowcase.astro';
import Insights from '../components/Insights.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Nav />
  <main>
    <Hero />
    <Problems />
    <Services />
    <Process />
    <About />
    <Proof />
    <ToolsShowcase />
    <Insights />
    <Newsletter />

    <!-- Bottom CTA -->
    <section class="bottom-cta">
      <div class="container">
        <h2>Ready to fix the stack?</h2>
        <p>45 minutes. I'll dig into your stack and tell you exactly what's broken.</p>
        <div class="bottom-cta__actions">
          <a href="https://calendly.com/mkultraman/mkultraman-exploratory-call" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Book an exploratory call ($175) &rarr;</a>
          <a href="/contact" class="bottom-cta__alt">prefer to write? send a message</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .bottom-cta {
    padding: var(--space-96) 0;
    text-align: center;
    border-top: 1px solid var(--border);
  }
  .bottom-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-16);
  }
  .bottom-cta p {
    font-size: 17px;
    color: var(--text-muted);
    margin-bottom: var(--space-32);
  }
  .bottom-cta__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-12);
  }
  .bottom-cta__alt {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
  }
  .bottom-cta__alt:hover { color: var(--text); }
</style>
