---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does Ongoing Management cover each month?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tool and vendor management (renewals, upgrades, cost reviews), workflow moni toring and iteration, new  tool evaluation and onboarding, incident response when something breaks, monthly review of operational metrics, and direct access for questions and quick tasks."
      }
    },
    {
      "@type": "Question",
      "name": "Does ongoing management require a Stack Audit first?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. All retainer clients start with a Stack Audit. This ensures the system we're managing is sound and I know the full picture before taking ongoing responsibility."
      }
    },
    {
      "@type": "Question",
      "name": "What is the minimum commitment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "3-month minimum. After that, month- to-month with 30 days notice  to cancel."
      }
    },
    {
      "@type": "Question",
      "name": "How do you handle urgent issues?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You have direct Slack access. For urgent incidents : something breaks, a vendor goes down, a critical process s tops working : I respond and work the problem. This isn't 24/7 on-call, but it's responsive access  to someone who knows your stack cold."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between this and just hiring someone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "$1,100/month versus ¥600K+ for a full-time IT manager : before benefits, onboarding time, and the risk of a single point of failure. You also don't get 6 months of ramp-up time. I know your stack from the audit forward."
      }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://www.mkultraman.com/#service-ongoing-management",
  "name": "Ongoing Management",
  "description": "Monthly infrastructure management retainer. Tool management, workflow moni toring, vendor relations, incident response, and direct access. Starting from $1,100/month.",
  "provider": {
    "@type": "Person",
    "@id": "https://www.mkultraman.com/#person",
    "name": "Matt Ketchum",
    "alternateName": "MKUltraman",
    "url": "https://www.mkultraman.com"
  },
  "areaServed": { "@type": "Country", "name": "Japan" },
  "offers": {
    "@type": "Offer",
    "price": "1100",
    "priceCurrency": "USD",
    "billingDuration": "P1M"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.mkultraman.com/" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://www.mkultraman.com/services/" },
    { "@type": "ListItem", "position": 3, "name": "Ongoing Management", "item": "https://www.mkultraman.com/services/ongoing-management/" }
  ]
};
---

<Base
  title="Ongoing Management : Monthly IT Retainer for Japan SMEs | MKUltraman"
  description="Monthly infrastructure management for SMEs in Japan. Tools, vendors, workflows, incident response, and direct access. Starting from $1,100/month."
>
  <Nav />

  <main>

    <!-- Hero -->
    <section class="mgmt-hero">
      <div class="container">
        <a href="/services" class="back-link">&larr; All services</a>
        <div class="hero- top">
          <span class="service-tag">03 &mdash; Monthly retainer · Ongoing</span>
        </div>
        <h1>Ongoing Management</h1>
        <p class="hero-lead">
          I stay in as your infrastructure opera tor. You don't have  to think
          about the stack. I handle it.
        </p>
        <div class="hero-specs">
          <div class="spec">
            <span class="spec-label">Commitment</span>
            <span class="spec-value">3-month minimum</span>
          </div>
          <div class="spec">
            <span class="spec-label">Access</span>
            <span class="spec-value">Slack + monthly calls</span>
          </div>
          <div class="spec">
            <span class="spec-label">Starting from</span>
            <span class="spec-value">$1,100 / month<span class="price-jpy" data-usd="1100"></span></span>
          </div>
        </div>
        <div class="hero-actions">
          <a href="https://calendly.com/mkultraman/mkultraman-explora tory-call" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Book an explora tory call : $175 &rarr;
          </a>
          <a href="/contact" class="hero-alt">or send a message</a>
        </div>
      </div>
    </section>

    <!-- The problem -->
    <section class="problem">
      <div class="container">
        <div class="problem__inner">
          <div class="problem__copy">
            <p class="eyebrow">The problem</p>
            <h2>Your stack is built. But it still needs someone watching it.</h2>
            <p>
              Tools get updated. Vendors change pricing or kill features. Au tomations
              break silently. The CRM someone set up properly last year starts accumulating
              junk data. A new team member joins and nobody onboards them in to the system.
            </p>
            <p>
              Ongoing management keeps the stack current, tight, and running. Monthly
              cost reviews, vendor renewals, workflow tune-ups, and direct access when
              something urgent comes up. You get someone who knows your operation cold,
              without the cost of a full-time hire.
            </p>
          </div>
          <div class="problem__stat-block">
            <div class="stat">
              <span class="stat__num">¥600K+</span>
              <span class="stat__label">Monthly cost of a full-time IT manager, before benefits</span>
            </div>
            <div class="stat">
              <span class="stat__num">6 months</span>
              <span class="stat__label">Typical ramp-up time for a new IT hire  to know your stack</span>
            </div>
            <div class="stat">
              <span class="stat__num">$1,100<span class="price-jpy" data-usd="1100"></span></span>
              <span class="stat__label">Starting monthly rate, no ramp-up required</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What's included -->
    <section class="included">
      <div class="container">
        <p class="eyebrow">What's covered monthly</p>
        <h2>Everything your stack needs  to keep running well.</h2>
        <div class="included__grid">
          <div class="included__item">
            <h3>Tool and vendor management</h3>
            <p>Renewals, upgrades, pricing negotiations, and cancellations handled without you having  to think about them. No surprise invoices.</p>
          </div>
          <div class="included__item">
            <h3>Workflow moni toring</h3>
            <p>Au tomations are checked. If something breaks or drifts, it gets caught before it becomes a problem. Iteration as your needs change.</p>
          </div>
          <div class="included__item">
            <h3>New  tool evaluation</h3>
            <p>When something new comes up : a vendor pitches you, a team member finds a  tool : you have someone  to evaluate it properly before you commit.</p>
          </div>
          <div class="included__item">
            <h3>Incident response</h3>
            <p>Something breaks. You message me. I work the problem. No ticket queues, no waiting for a vendor  to reply  to your support email.</p>
          </div>
          <div class="included__item">
            <h3>Monthly operational review</h3>
            <p>A monthly call covering what changed, what's working, what needs attention. Your stack's health in plain language.</p>
          </div>
          <div class="included__item">
            <h3>Direct access</h3>
            <p>Slack access for questions and quick tasks. The answer  to "how do I do X in our system" shouldn't require a calendar invite.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it starts -->
    <section class="onboarding">
      <div class="container">
        <p class="eyebrow">How it starts</p>
        <h2>Every retainer begins with an audit.</h2>
        <div class="onboarding__inner">
          <div class="onboarding__copy">
            <p>
              All retainer clients start with a <a href="/services/stack-audit">Stack Audit</a>.
              Before I take ongoing responsibility for your infrastructure, I need  to know
              exactly what I'm managing. The audit establishes the baseline : what you have,
              what it costs, where the risks are.
            </p>
            <p>
              If you've already done a Stack Audit with me, we can go straight  to scoping
              the retainer. If you haven't, we start there.
            </p>
            <p>
              After the audit, we agree on scope and start date. Month one typically involves
              some cleanup from the audit findings. From month two on, it's steady-state
              management with monthly reviews.
            </p>
          </div>
          <div class="onboarding__path">
            <div class="path-step">
              <span class="path-num">01</span>
              <div>
                <h3>Stack Audit</h3>
                <p>Establish baseline. Understand the full picture.</p>
              </div>
            </div>
            <div class="path-arrow">&darr;</div>
            <div class="path-step">
              <span class="path-num">02</span>
              <div>
                <h3>Retainer kickoff</h3>
                <p>Agree on scope, access, and communication cadence.</p>
              </div>
            </div>
            <div class="path-arrow">&darr;</div>
            <div class="path-step">
              <span class="path-num">03</span>
              <div>
                <h3>Ongoing management</h3>
                <p>Monthly reviews, direct access, incidents handled.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq">
      <div class="container">
        <p class="eyebrow">Questions</p>
        <h2>Common questions about the retainer.</h2>
        <div class="faq__list">
          <details class="faq__item">
            <summary>What's the minimum commitment?</summary>
            <p>3-month minimum. After that, month- to-month with 30 days notice  to cancel. The 3-month minimum exists because meaningful infrastructure management requires continuity : one month isn't enough  to establish a reliable picture.</p>
          </details>
          <details class="faq__item">
            <summary>How do you handle urgent issues?</summary>
            <p>You have direct Slack access. For urgent incidents : something breaks, a vendor goes down, a critical process s tops working : I respond and work the problem. This isn't 24/7 on-call, but it's responsive access  to someone who knows your stack cold.</p>
          </details>
          <details class="faq__item">
            <summary>What's not included?</summary>
            <p>Software development, engineering work, or major new builds. If we identify that a significant new system needs  to be built, that's scoped separately as an <a href="/services/infrastructure-build">Infrastructure Build</a>. The retainer is operations and management, not development.</p>
          </details>
          <details class="faq__item">
            <summary>Do you work with Japanese-language  tools?</summary>
            <p>Yes. I work in Japanese and manage  tools common in Japan : Kin tone, Cybozu, Chatwork, LINE WORKS, freee, and others. Most retainer clients have a mix of global and Japan-specific  tools in their stack.</p>
          </details>
          <details class="faq__item">
            <summary>What's the difference between this and just hiring someone?</summary>
            <p>$1,100/month versus ¥600K+ for a full-time IT manager, before benefits. No onboarding time : I know your stack from the audit forward. No single point of failure : the knowledge lives in documentation, not in one person's head.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- Bot tom CTA -->
    <section class="cta-bot tom">
      <div class="container">
        <h2>S top managing your stack yourself.</h2>
        <p>45 minutes. We'll talk through your situation and figure out if this is the right fit.</p>
        <div class="cta-bot tom__actions">
          <a href="https://calendly.com/mkultraman/mkultraman-explora tory-call" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Book an explora tory call : $175 &rarr;
          </a>
          <a href="/contact" class="cta-bot tom__alt">or send a message</a>
        </div>
        <div class="cta-bot tom__other">
          <p>Also looking at:</p>
          <a href="/services/stack-audit">Stack Audit &rarr;</a>
          <a href="/services/infrastructure-build">Infrastructure Build &rarr;</a>
        </div>
      </div>
    </section>

  </main>

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Footer />
</Base>

<style>
  /* Hero */
  .mgmt-hero {
    padding: var(--space-96) 0 var(--space-64);
    border-bot tom: 1px solid var(--border);
  }
  .back-link {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
    display: inline-block;
    margin-bot tom: var(--space-32);
  }
  .back-link:hover { color: var(--text); }
  .hero- top { margin-bot tom: var(--space-16); }
  .service-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .mgmt-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 900;
    color: var(--text);
    letter-spacing: -0.025em;
    line-height: 1.0;
    margin-bot tom: var(--space-16);
  }
  .hero-lead {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 560px;
    margin-bot tom: var(--space-32);
  }
  .hero-specs {
    display: flex;
    gap: var(--space-48);
    flex-wrap: wrap;
    margin-bot tom: var(--space-32);
    padding: var(--space-24) 0;
    border- top: 1px solid var(--border);
    border-bot tom: 1px solid var(--border);
  }
  .spec { display: flex; flex-direction: column; gap: var(--space-4); }
  .spec-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .spec-value {
    font-size: 15px;
    color: var(--text);
    font-weight: 500;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-16);
  }
  .hero-alt {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
  }
  .hero-alt:hover { color: var(--text); }

  /* Problem */
  .problem {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
  }
  .problem__inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-64);
    align-items: start;
  }
  .problem__copy h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-24);
  }
  .problem__copy p {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bot tom: var(--space-24);
  }
  .problem__stat-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
    padding: var(--space-32);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bot tom: var(--space-24);
    border-bot tom: 1px solid var(--border);
  }
  .stat:last-child { border-bot tom: none; padding-bot tom: 0; }
  .stat__num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 900;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .stat__label {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Included */
  .included {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
  }
  .included h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-64);
  }
  .included__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
  }
  .included__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  .included__item h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .included__item p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Onboarding */
  .onboarding {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
    background: var(--surface);
  }
  .onboarding h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-48);
  }
  .onboarding__inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-64);
    align-items: start;
  }
  .onboarding__copy p {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bot tom: var(--space-24);
  }
  .onboarding__copy a { color: var(--accent); }
  .onboarding__path {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .path-step {
    display: flex;
    gap: var(--space-16);
    padding: var(--space-16) var(--space-24);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .path-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.08em;
    flex-shrink: 0;
    padding- top: 2px;
  }
  .path-step h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bot tom: var(--space-4);
  }
  .path-step p {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .path-arrow {
    text-align: center;
    color: var(--border);
    font-size: 18px;
    padding: var(--space-8) 0;
  }

  /* FAQ */
  .faq {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
  }
  .faq h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-48);
  }
  .faq__list {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .faq__item {
    padding: var(--space-24);
    border-bot tom: 1px solid var(--border);
  }
  .faq__item:last-child { border-bot tom: none; }
  .faq__item summary {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::after {
    content: '+';
    font-size: 18px;
    color: var(--text-dim);
    flex-shrink: 0;
    margin-left: var(--space-16);
  }
  .faq__item[open] summary::after { content: '  to '; }
  .faq__item p {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin- top: var(--space-16);
  }
  .faq__item p a { color: var(--accent); }

  /* Bot tom CTA */
  .cta-bot tom {
    padding: var(--space-96) 0;
    text-align: center;
  }
  .cta-bot tom h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 900;
    color: var(--text);
    margin-bot tom: var(--space-16);
    letter-spacing: -0.02em;
  }
  .cta-bot tom p {
    font-size: 17px;
    color: var(--text-muted);
    margin-bot tom: var(--space-32);
  }
  .cta-bot tom__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-12);
    margin-bot tom: var(--space-48);
  }
  .cta-bot tom__alt {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
  }
  .cta-bot tom__alt:hover { color: var(--text); }
  .cta-bot tom__other {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-24);
    flex-wrap: wrap;
  }
  .cta-bot tom__other p {
    font-size: 13px;
    color: var(--text-dim);
    margin: 0;
  }
  .cta-bot tom__other a {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
  }
  .cta-bot tom__other a:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .problem__inner { grid-template-columns: 1fr; }
    .included__grid { grid-template-columns: 1fr; }
    .onboarding__inner { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
  }
</style>
