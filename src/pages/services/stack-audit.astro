---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does a Stack Audit actually cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A full inven tory of every  tool, subscription, and integration your business runs. Workflow mapping : how work actually moves, not how it's supposed  to. Cost analysis of what you're paying versus what you're getting. Friction points where time and money are being lost. A written report with prioritized recommendations and a 60-minute debrief call."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a Stack Audit take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Typically 1  to 2 weeks from kickoff  to delivery of the written report, depending on the complexity of your stack and how quickly your team can share access and documentation."
      }
    },
    {
      "@type": "Question",
      "name": "What do I need  to prepare before the audit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A list of the  tools you currently use, your billing statements or invoices for those  tools, and 30  to 60 minutes with a key team member who knows how work actually flows day  to day. That's it."
      }
    },
    {
      "@type": "Question",
      "name": "Do you work with businesses that don't have an IT team?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes : that's the typical client. Most SMEs in Japan don't have dedicated IT staff. The Stack Audit is designed  to make sense  to operations owners and managing direc tors, not engineers."
      }
    },
    {
      "@type": "Question",
      "name": "What happens after the audit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You get a written report with prioritized recommendations and a 60-minute debrief call where we walk through the findings  together. From there, you decide what  to act on. Some clients implement changes themselves. Others move  to an Infrastructure Build or an ongoing retainer. There's no obligation beyond the audit."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a Stack Audit cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Starting from $1,000. Final pricing depends on the size and complexity of the business. Most clients recover the cost within 30 days by eliminating redundant  tools or fixing a process that was silently burning hours."
      }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://www.mkultraman.com/#service-stack-audit",
  "name": "Stack Audit",
  "description": "A diagnostic of everything your business runs on. Tools, workflows, costs, and where the friction is coming from. Delivered as a written report with a 60-minute debrief call.",
  "provider": {
    "@type": "Person",
    "@id": "https://www.mkultraman.com/#person",
    "name": "Matt Ketchum",
    "alternateName": "MKUltraman",
    "url": "https://www.mkultraman.com"
  },
  "areaServed": { "@type": "Country", "name": "Japan" },
  "offers": {
    "@type": "Offer",
    "price": "1000",
    "priceCurrency": "USD",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "description": "Starting from $1,000. Final pricing based on complexity."
    }
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.mkultraman.com/" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://www.mkultraman.com/services/" },
    { "@type": "ListItem", "position": 3, "name": "Stack Audit", "item": "https://www.mkultraman.com/services/stack-audit/" }
  ]
};
---

<Base
  title="Stack Audit : Digital Infrastructure Diagnostic for Japan SMEs | MKUltraman"
  description="A full diagnostic of your business's  tools, workflows, and costs. Written report + 60-min debrief. Starting from $1,000. For SMEs in Japan."
>
  <Nav />

  <main>

    <!-- Hero -->
    <section class="audit-hero">
      <div class="container">
        <a href="/services" class="back-link">&larr; All services</a>
        <div class="hero- top">
          <span class="service-tag">01 &mdash; One-time · Fixed fee</span>
        </div>
        <h1>Stack Audit</h1>
        <p class="hero-lead">
          A diagnostic of everything your business runs on. Tools, workflows,
          costs, and where the friction is coming from.
        </p>
        <div class="hero-specs">
          <div class="spec">
            <span class="spec-label">Timeline</span>
            <span class="spec-value">1  to 2 weeks</span>
          </div>
          <div class="spec">
            <span class="spec-label">Deliverable</span>
            <span class="spec-value">Written report + call</span>
          </div>
          <div class="spec">
            <span class="spec-label">Starting from</span>
            <span class="spec-value">$1,000<span class="price-jpy" data-usd="1000"></span></span>
          </div>
        </div>
        <div class="hero-actions">
          <a href="https://calendly.com/mkultraman/mkultraman-explora tory-call" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Book an explora tory call : $175 &rarr;
          </a>
          <a href="/contact" class="hero-alt">or send a message</a>
        </div>
      </div>
    </section>

    <!-- The problem -->
    <section class="problem">
      <div class="container">
        <div class="problem__inner">
          <div class="problem__copy">
            <p class="eyebrow">The problem</p>
            <h2>Most SMEs in Japan don't know what they're running.</h2>
            <p>
              You have Slack, Kintone, a Google Workspace, some spreadsheets, a CRM
              someone set up three years ago, and about six other things that were
              added over time without a plan. Nobody knows what's connected  to what.
              Nobody knows what's actually being used. Nobody knows what it's costing.
            </p>
            <p>
              The Stack Audit maps all of it. You get a clear picture of your full
              operational footprint : what you have, what it costs, how it fits
               together, and where the friction is. Most clients are surprised. A few
              are alarmed. All of them end up with a plan.
            </p>
          </div>
          <div class="problem__stat-block">
            <div class="stat">
              <span class="stat__num">¥5  to 8M</span>
              <span class="stat__label">Annual cost of an internal IT hire, before benefits</span>
            </div>
            <div class="stat">
              <span class="stat__num">30 days</span>
              <span class="stat__label">Typical time for clients  to recover the audit cost</span>
            </div>
            <div class="stat">
              <span class="stat__num">$1,000<span class="price-jpy" data-usd="1000"></span></span>
              <span class="stat__label">Starting price for a full diagnostic</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What's included -->
    <section class="included">
      <div class="container">
        <p class="eyebrow">What's included</p>
        <h2>Everything you need  to understand your stack.</h2>
        <div class="included__grid">
          <div class="included__item">
            <h3>Tool inven tory</h3>
            <p>Complete list of every  tool, subscription, and service your business pays for or depends on. Including the ones you forgot about.</p>
          </div>
          <div class="included__item">
            <h3>Workflow mapping</h3>
            <p>How work actually moves through your organization : not the org chart version, the real version. Where things slow down, get dropped, or require manual correction.</p>
          </div>
          <div class="included__item">
            <h3>Cost analysis</h3>
            <p>What you're paying, broken down by  tool category. Where you're paying twice for the same capability. What you're paying for that nobody uses.</p>
          </div>
          <div class="included__item">
            <h3>Friction points</h3>
            <p>The specific places where time and money are being lost. Ranked by impact so you know what  to fix first.</p>
          </div>
          <div class="included__item">
            <h3>Written report</h3>
            <p>A clear, prioritized document you can actually act on. Findings, recommendations, and next steps. Written for operators, not engineers.</p>
          </div>
          <div class="included__item">
            <h3>60-minute debrief call</h3>
            <p>We walk through the findings  together. You ask questions. You leave knowing exactly what  to do next.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="process">
      <div class="container">
        <p class="eyebrow">How it works</p>
        <h2>Four steps. Two weeks. One clear picture.</h2>
        <div class="process__steps">
          <div class="process__step">
            <span class="step-num">01</span>
            <div class="step-content">
              <h3>Kickoff call</h3>
              <p>30 minutes. We establish scope, share access, and align on what a successful audit looks like for your situation.</p>
            </div>
          </div>
          <div class="process__step">
            <span class="step-num">02</span>
            <div class="step-content">
              <h3>Discovery</h3>
              <p>I map your  tools, workflows, and costs. I'll ask for documentation, billing access, and a working session with whoever knows how things actually work.</p>
            </div>
          </div>
          <div class="process__step">
            <span class="step-num">03</span>
            <div class="step-content">
              <h3>Report delivery</h3>
              <p>Written audit report sent via email. Includes findings, prioritized recommendations, and a clear summary of your full stack.</p>
            </div>
          </div>
          <div class="process__step">
            <span class="step-num">04</span>
            <div class="step-content">
              <h3>Debrief call</h3>
              <p>60 minutes  to walk through the report  together. We cover the key findings, you ask questions, and we discuss next steps.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Good fit -->
    <section class="fit">
      <div class="container">
        <div class="fit__inner">
          <div>
            <p class="eyebrow">Good fit if</p>
            <ul class="fit__list">
              <li>You're paying for  tools you don't fully understand or use</li>
              <li>Work keeps falling through the cracks between systems</li>
              <li>You're growing but your operational setup hasn't kept up</li>
              <li>Something is costing more time than it should but you can't pin down what</li>
              <li>You want a clear baseline before making any infrastructure decisions</li>
            </ul>
          </div>
          <div>
            <p class="eyebrow">Not a fit if</p>
            <ul class="fit__list fit__list--dim">
              <li>You already have a clear, documented picture of your stack</li>
              <li>You have an internal IT team handling this already</li>
              <li>You're looking for software development or engineering work</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq">
      <div class="container">
        <p class="eyebrow">Questions</p>
        <h2>Common questions about the Stack Audit.</h2>
        <div class="faq__list">
          <details class="faq__item">
            <summary>What do I need  to prepare before the audit?</summary>
            <p>A list of the  tools you currently use, your billing statements or invoices for those  tools, and 30  to 60 minutes with a key team member who knows how work flows day  to day. That's it.</p>
          </details>
          <details class="faq__item">
            <summary>Do you work with businesses that don't have an IT team?</summary>
            <p>Yes : that's the typical client. Most SMEs in Japan don't have dedicated IT staff. The Stack Audit is designed  to make sense  to operations owners and managing direc tors, not engineers.</p>
          </details>
          <details class="faq__item">
            <summary>What happens after the audit?</summary>
            <p>You get a written report and a 60-minute debrief call. From there, you decide what  to act on. Some clients implement changes themselves. Others move  to an <a href="/services/infrastructure-build">Infrastructure Build</a> or an <a href="/services/ongoing-management">ongoing retainer</a>. There's no obligation beyond the audit.</p>
          </details>
          <details class="faq__item">
            <summary>Do you work in Japanese?</summary>
            <p>Yes. I'm based in Tokyo and work with Japanese-speaking teams. Reports can be delivered in English or Japanese depending on your preference.</p>
          </details>
          <details class="faq__item">
            <summary>How is pricing determined?</summary>
            <p>Starting from $1,000. Final pricing depends on the size and complexity of the business. We confirm scope and price before any work begins. Most clients recover the cost inside 30 days.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- Bot tom CTA -->
    <section class="cta-bot tom">
      <div class="container">
        <h2>Start with a conversation.</h2>
        <p>45 minutes. We'll dig in to your situation and you'll know whether this is the right move.</p>
        <div class="cta-bot tom__actions">
          <a href="https://calendly.com/mkultraman/mkultraman-explora tory-call" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Book an explora tory call : $175 &rarr;
          </a>
          <a href="/contact" class="cta-bot tom__alt">or send a message</a>
        </div>
        <div class="cta-bot tom__other">
          <p>Also looking at:</p>
          <a href="/services/infrastructure-build">Infrastructure Build &rarr;</a>
          <a href="/services/ongoing-management">Ongoing Management &rarr;</a>
        </div>
      </div>
    </section>

  </main>

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Footer />
</Base>

<style>
  /* Hero */
  .audit-hero {
    padding: var(--space-96) 0 var(--space-64);
    border-bot tom: 1px solid var(--border);
  }
  .back-link {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
    display: inline-block;
    margin-bot tom: var(--space-32);
  }
  .back-link:hover { color: var(--text); }
  .hero- top {
    margin-bot tom: var(--space-16);
  }
  .service-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .audit-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 900;
    color: var(--text);
    letter-spacing: -0.025em;
    line-height: 1.0;
    margin-bot tom: var(--space-16);
  }
  .hero-lead {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 560px;
    margin-bot tom: var(--space-32);
  }
  .hero-specs {
    display: flex;
    gap: var(--space-48);
    flex-wrap: wrap;
    margin-bot tom: var(--space-32);
    padding: var(--space-24) 0;
    border- top: 1px solid var(--border);
    border-bot tom: 1px solid var(--border);
  }
  .spec { display: flex; flex-direction: column; gap: var(--space-4); }
  .spec-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .spec-value {
    font-size: 15px;
    color: var(--text);
    font-weight: 500;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-16);
  }
  .hero-alt {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
  }
  .hero-alt:hover { color: var(--text); }

  /* Problem */
  .problem {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
  }
  .problem__inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-64);
    align-items: start;
  }
  .problem__copy h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-24);
  }
  .problem__copy p {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bot tom: var(--space-24);
  }
  .problem__stat-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
    padding: var(--space-32);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bot tom: var(--space-24);
    border-bot tom: 1px solid var(--border);
  }
  .stat:last-child { border-bot tom: none; padding-bot tom: 0; }
  .stat__num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 900;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .stat__label {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* What's included */
  .included {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
  }
  .included h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-64);
  }
  .included__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
  }
  .included__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  .included__item h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .included__item p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Process */
  .process {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
    background: var(--surface);
  }
  .process h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-64);
  }
  .process__steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .process__step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-32);
    padding: var(--space-32);
    border-bot tom: 1px solid var(--border);
    background: var(--bg);
  }
  .process__step:last-child { border-bot tom: none; }
  .step-num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.08em;
    padding- top: 3px;
  }
  .step-content h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bot tom: var(--space-8);
  }
  .step-content p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Fit */
  .fit {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
  }
  .fit__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-64);
  }
  .fit__inner .eyebrow { margin-bot tom: var(--space-16); }
  .fit__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  .fit__list li {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.5;
    padding-left: var(--space-16);
    position: relative;
  }
  .fit__list li::before {
    content: ':';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 12px;
  }
  .fit__list--dim li { color: var(--text-dim); }
  .fit__list--dim li::before { color: var(--border); }

  /* FAQ */
  .faq {
    padding: var(--space-96) 0;
    border-bot tom: 1px solid var(--border);
  }
  .faq h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-48);
  }
  .faq__list {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .faq__item {
    padding: var(--space-24);
    border-bot tom: 1px solid var(--border);
  }
  .faq__item:last-child { border-bot tom: none; }
  .faq__item summary {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::after {
    content: '+';
    font-size: 18px;
    color: var(--text-dim);
    flex-shrink: 0;
    margin-left: var(--space-16);
  }
  .faq__item[open] summary::after { content: '  to '; }
  .faq__item p {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin- top: var(--space-16);
  }
  .faq__item p a {
    color: var(--accent);
  }

  /* Bot tom CTA */
  .cta-bot tom {
    padding: var(--space-96) 0;
    text-align: center;
  }
  .cta-bot tom h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 900;
    color: var(--text);
    margin-bot tom: var(--space-16);
    letter-spacing: -0.02em;
  }
  .cta-bot tom p {
    font-size: 17px;
    color: var(--text-muted);
    margin-bot tom: var(--space-32);
  }
  .cta-bot tom__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-12);
    margin-bot tom: var(--space-48);
  }
  .cta-bot tom__alt {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
  }
  .cta-bot tom__alt:hover { color: var(--text); }
  .cta-bot tom__other {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-24);
    flex-wrap: wrap;
  }
  .cta-bot tom__other p {
    font-size: 13px;
    color: var(--text-dim);
    margin: 0;
  }
  .cta-bot tom__other a {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
  }
  .cta-bot tom__other a:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .problem__inner { grid-template-columns: 1fr; }
