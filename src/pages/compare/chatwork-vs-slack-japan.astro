                <tr>
                  <td>Vendor</td>
                  <td>Chatwork (Japan)</td>
                  <td>Salesforce (US)</td>
                </tr>
                <tr>
                  <td>Category</td>
                  <td>Business messaging</td>
                  <td>Team collaboration platform</td>
                </tr>
