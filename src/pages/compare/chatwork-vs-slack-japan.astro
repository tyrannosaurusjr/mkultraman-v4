                  <td>Native (Kintone, freee, SmartHR, KING OF TIME)</td>
                  <td>Via Zapier/Make primarily</td>
                </tr>
                <tr>
                  <td>Video calls</td>
                  <td>Basic built-in</td>
                  <td>Huddles (excellent)</td>
                </tr>
                <tr>
                  <td>App integrations</td>
                  <td>~30 native</td>
                  <td>2,600+ apps</td>
                </tr>
                <tr>
                  <td>Mobile UX</td>
