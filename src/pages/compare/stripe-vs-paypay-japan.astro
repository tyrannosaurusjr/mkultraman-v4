<Base
  title="Stripe vs PayPay for Japan Businesses: Honest Comparison - MKUltraman"
  description="Stripe vs PayPay for Japan businesses - fees, use cases, foreign founders, and why these tools solve different problems for the Japan payment stack."
  article={true}
