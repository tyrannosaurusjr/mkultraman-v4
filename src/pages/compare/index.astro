---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const comparisons = [
  {
    slug: 'kintone-vs-salesforce',
    title: 'Kintone vs Salesforce for Japan SMEs',
    description: 'Detailed comparison of Kintone and Salesforce covering pricing, use cases, implementation costs, and when each platform actually makes sense.',
    readingTime: '~10 min',
    lastVerified: '2026-04-22',
  },
  {
    slug: 'freee-vs-money-forward',
    title: 'freee vs Money Forward Cloud for Japan SMEs',
    description: 'Honest comparison of Japan\'s two dominant cloud accounting platforms: pricing, インボイス and 電子帳簿保存法 compliance, bank sync coverage, and how to choose based on your 税理士 and workflow.',
    readingTime: '~9 min',
    lastVerified: '2026-04-22',
  },
  {
    slug: 'chatwork-vs-slack-japan',
    title: 'Chatwork vs Slack for Japan Teams',
    description: 'Chatwork dominates Japan SMEs for a reason, but Slack wins for international teams and heavy integrations. Honest breakdown of pricing, Japanese SaaS ecosystem fit, and when each platform makes sense.',
    readingTime: '~8 min',
    lastVerified: '2026-04-23',
  },
  {
    slug: 'backlog-vs-jira',
    title: 'Backlog vs Jira for Japan Teams',
    description: 'Backlog is Japan\'s most-used project management tool for a reason - simpler, cheaper, and native Japanese support. Jira wins only at enterprise Agile scale. Honest comparison with real pricing.',
    readingTime: '~8 min',
    lastVerified: '2026-04-23',
  },
  {
    slug: 'zoom-vs-google-meet-vs-teams-japan',
    title: 'Zoom vs Google Meet vs Teams for Japan',
    description: 'Three-way comparison of the video platforms Japan businesses actually use - pricing reality, Japan enterprise adoption, ecosystem fit, and when Zoom is worth paying for vs using what\'s already bundled.',
    readingTime: '~9 min',
    lastVerified: '2026-04-23',
  },
  {
    slug: 'webflow-vs-wordpress-japan',
    title: 'Webflow vs WordPress for Japan SMEs',
    description: 'Japan\'s client handoff reality, SEO tooling, true cost over 3 years, and when each platform makes sense, including the Japanese 担当者 self-management problem that most comparisons miss.',
    readingTime: '~9 min',
    lastVerified: '2026-04-23',
  },
  {
    slug: 'google-workspace-vs-microsoft-365-japan',
    title: 'Google Workspace vs Microsoft 365 for Japan SMEs',
    description: 'Japan\'s Excel dependency is the real deciding factor. Honest comparison of pricing, Japanese SaaS integrations, client document exchange reality, and which suite fits your business.',
    readingTime: '~9 min',
    lastVerified: '2026-04-23',
  },
  {
    slug: 'zapier-vs-make-japan',
    title: 'Zapier vs Make for Japan SMEs',
    description: 'Zapier for beginners. Make for power users. Honest comparison of tasks vs operations billing, Japan SaaS integrations, complexity ceiling, and when to migrate between them.',
    readingTime: '~8 min',
    lastVerified: '2026-04-23',
  },
  {
    slug: 'stripe-vs-paypay-japan',
    title: 'Stripe vs PayPay for Japan Businesses',
    description: 'These solve different problems: Stripe for online payments, PayPay for in-person QR. Most Japan businesses need both. Honest breakdown of fees, foreign founder setup, and how to build the right payment stack.',
    readingTime: '~8 min',
    lastVerified: '2026-04-23',
  },
];

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "https://www.mkultraman.com/compare/#collectionpage",
  "name": "Tool Comparisons - MKUltraman",
  "description": "Honest, operator-grounded comparisons of the tools Japan SMEs evaluate most often. No affiliate kickbacks, no vendor favoritism.",
  "url": "https://www.mkultraman.com/compare/",
  "isPartOf": { "@id": "https://www.mkultraman.com/#website" },
  "hasPart": comparisons.map(c => ({
    "@type": "Article",
    "url": `https://www.mkultraman.com/compare/${c.slug}/`,
    "name": c.title,
    "description": c.description
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.mkultraman.com/" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://www.mkultraman.com/compare/" }
  ]
};
---

<Base
  title="Tool Comparisons - MKUltraman"
  description="Honest, operator-grounded comparisons of the tools Japan SMEs evaluate most often. Kintone vs Salesforce, Freee vs Money Forward, and more."
>
  <Nav />

  <main class="compare-hub">
    <div class="container">
      <header class="hub-header">
        <span class="hub-eyebrow">Compare</span>
        <h1>Honest tool comparisons for Japan SMEs.</h1>
        <p class="hub-lead">
          The comparisons you'd actually ask a trusted operator, written from
          direct implementation experience with foreign-owned and Japanese SMEs.
          No vendor kickbacks. No affiliate programs. The goal is to save you
          from the wrong purchase, not to close the sale.
        </p>
      </header>

      <ul class="compare-list">
        {comparisons.map(c => (
          <li class="compare-card">
            <a href={`/compare/${c.slug}/`} class="compare-card__link">
              <div class="compare-card__meta">
                <span>Last verified {c.lastVerified}</span>
                <span>·</span>
                <span>{c.readingTime}</span>
              </div>
              <h2 class="compare-card__title">{c.title}</h2>
              <p class="compare-card__description">{c.description}</p>
              <span class="compare-card__arrow">Read the comparison →</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Base>

<style>
  .compare-hub {
    padding: var(--space-96) 0;
    background: var(--bg);
    min-height: 100vh;
  }

  .hub-header {
    max-width: 720px;
    margin-bottom: var(--space-64);
  }
  .hub-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-16);
  }
  .hub-header h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: var(--text);
    line-height: 1.05;
    margin-bottom: var(--space-24);
  }
  .hub-lead {
    font-size: 18px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .compare-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    max-width: 820px;
  }
  .compare-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: border-color 0.15s, transform 0.15s;
  }
  .compare-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .compare-card__link {
    display: block;
    padding: var(--space-32);
    color: inherit;
  }
  .compare-card__meta {
    display: flex;
    gap: var(--space-8);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-16);
  }
  .compare-card__title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 24px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin-bottom: var(--space-12);
  }
  .compare-card__description {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-20);
  }
  .compare-card__arrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .compare-card__link { padding: var(--space-24); }
  }
</style>
