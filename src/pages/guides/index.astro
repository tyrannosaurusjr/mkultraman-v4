---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const guides = [
  {
    slug: 'fractional-it-manager-japan',
    title: 'Fractional IT Manager in Japan: The Complete Guide for SMEs',
    description: 'What a fractional IT manager does, what it costs vs a full-time hire in Japan, when to engage one, and how to evaluate candidates.',
    readingTime: '~12 min',
    updated: '2026-04-22',
  },
  {
    slug: 'japan-sme-tech-stack',
    title: 'Japan SME Tech Stack: The Complete Guide for 2026',
    description: 'The five-layer framework for building a healthy tech stack in Japan — communication, project management, accounting, CRM, and payments. With real costs for a 15-person business.',
    readingTime: '~12 min',
    updated: '2026-04-23',
  },
  {
    slug: 'crm-for-japan-sme',
    title: 'CRM for Japan SMEs: The Complete Buying Guide',
    description: 'Why most Japan SME CRM deployments fail, how to choose the right platform, Japan-specific configuration tips, and when a spreadsheet is genuinely the right answer.',
    readingTime: '~11 min',
    updated: '2026-04-23',
  },
  {
    slug: 'accepting-payments-japan',
    title: 'Accepting Payments in Japan: The Complete Guide for SMEs',
    description: 'Stripe, PayPay, bank transfer, convenience store payment, and IC cards — what you actually need for a full Japan payment stack, with a foreign founder angle.',
    readingTime: '~10 min',
    updated: '2026-04-23',
  },
  {
    slug: 'japan-saas-compliance',
    title: 'Japan SaaS Compliance: インボイス制度 and 電子帳簿保存法 for SMEs',
    description: 'Plain-language guide to what Japan\'s qualified invoice system and electronic bookkeeping law actually require from your SaaS stack — minimum viable compliance setup included.',
    readingTime: '~10 min',
    updated: '2026-04-23',
  },
  {
    slug: 'hiring-employees-japan',
    title: 'Hiring Employees in Japan: The SME Guide to Payroll, HR Tools, and Compliance',
    description: 'Social insurance, labor contracts, paid leave law, My Number, and the HR SaaS tools that handle Japanese payroll compliance — for SMEs hiring 1–50 employees.',
    readingTime: '~10 min',
    updated: '2026-04-23',
  },
];

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "https://www.mkultraman.com/guides/#collectionpage",
  "name": "Guides — MKUltraman",
  "description": "Long-form guides on digital infrastructure, fractional IT management, and tech stack decisions for SMEs in Japan.",
  "url": "https://www.mkultraman.com/guides/",
  "isPartOf": { "@id": "https://www.mkultraman.com/#website" },
  "hasPart": guides.map(g => ({
    "@type": "Article",
    "url": `https://www.mkultraman.com/guides/${g.slug}/`,
    "name": g.title,
    "description": g.description
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.mkultraman.com/" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://www.mkultraman.com/guides/" }
  ]
};
---

<Base
  title="Guides — MKUltraman"
  description="Long-form guides on digital infrastructure, fractional IT management, and tech stack decisions for SMEs in Japan."
>
  <Nav />

  <main class="guides-hub">
    <div class="container">
      <header class="hub-header">
        <span class="hub-eyebrow">Guides</span>
        <h1>Deep references for operators in Japan.</h1>
        <p class="hub-lead">
          Comprehensive, maintained guides on the infrastructure decisions
          facing foreign-owned and Japanese SMEs. Written from direct
          engagement work, updated as the landscape changes.
        </p>
      </header>

      <ul class="guide-list">
        {guides.map(g => (
          <li class="guide-card">
            <a href={`/guides/${g.slug}/`} class="guide-card__link">
              <div class="guide-card__meta">
                <span>Updated {g.updated}</span>
                <span>·</span>
                <span>{g.readingTime}</span>
              </div>
              <h2 class="guide-card__title">{g.title}</h2>
              <p class="guide-card__description">{g.description}</p>
              <span class="guide-card__arrow">Read the guide →</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Base>

<style>
  .guides-hub {
    padding: var(--space-96) 0;
    background: var(--bg);
    min-height: 100vh;
  }

  .hub-header {
    max-width: 720px;
    margin-bottom: var(--space-64);
  }
  .hub-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-16);
  }
  .hub-header h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: var(--text);
    line-height: 1.05;
    margin-bottom: var(--space-24);
  }
  .hub-lead {
    font-size: 18px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .guide-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    max-width: 820px;
  }
  .guide-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: border-color 0.15s, transform 0.15s;
  }
  .guide-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .guide-card__link {
    display: block;
    padding: var(--space-32);
    color: inherit;
  }
  .guide-card__meta {
    display: flex;
    gap: var(--space-8);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-16);
  }
  .guide-card__title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 24px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin-bottom: var(--space-12);
  }
  .guide-card__description {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-20);
  }
  .guide-card__arrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .guide-card__link { padding: var(--space-24); }
  }
</style>
