---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Privacy Policy — MKUltraman" description="How MKUltraman handles your data." noindex={true}>
  <Nav />
  <main class="legal">
    <div class="container">
      <h1>Privacy Policy</h1>
      <p class="updated">Last updated: April 2026</p>

      <h2>What data we collect</h2>
      <p>When you submit the inquiry form, we collect your name, email address, and the message you send. This data is processed by Formspree and forwarded to us by email. We do not store it in any database.</p>

      <h2>How we use it</h2>
      <p>Your information is used solely to respond to your inquiry. We do not sell, share, or use it for marketing without your consent.</p>

      <h2>Analytics</h2>
      <p>This site uses Google Analytics 4 and Vercel Analytics to measure page traffic. Google Analytics collects anonymized usage data including pages visited, session duration, and referral source. No ad targeting or remarketing is enabled. You can opt out via <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer">Google's opt-out browser add-on</a>.</p>

      <h2>Cookies</h2>
      <p>This site does not use cookies.</p>

      <h2>Your rights</h2>
      <p>You may request deletion of any data you submitted via the inquiry form by emailing <a href="mailto:hello@mkultraman.com">hello@mkultraman.com</a>.</p>

      <h2>Contact</h2>
      <p>Questions? <a href="mailto:hello@mkultraman.com">hello@mkultraman.com</a></p>

      <p class="back"><a href="/">← Back to home</a></p>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .legal {
    padding: var(--space-96) 0;
  }
  .legal h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 900;
    color: var(--text);
    margin-bottom: var(--space-8);
  }
  .updated {
    font-size: 13px;
    color: var(--text-dim);
    margin-bottom: var(--space-64);
  }
  .legal h2 {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    margin: var(--space-32) 0 var(--space-12);
  }
  .legal p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 680px;
  }
  .legal a { color: var(--accent); }
  .back { margin-top: var(--space-64); }
</style>
