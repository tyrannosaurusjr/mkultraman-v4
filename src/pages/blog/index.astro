---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
};
---

<Base title="Blog — MKUltraman" description="Field notes on digital infrastructure, business strategy, and market dynamics in Japan.">
  <Nav />

  <main class="blog-index">
    <div class="container">
      <div class="blog-header">
        <p class="eyebrow">Field notes</p>
        <h1 class="blog-headline">What I'm watching in Japan.</h1>
        <p class="blog-description">
          Insights on digital infrastructure, business strategy, and market dynamics
          from the ground in Tokyo.
        </p>
      </div>

      <div class="posts-grid">
        {sortedPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-card__meta">
              <time class="post-date">{formatDate(post.data.pubDate)}</time>
              <div class="post-card__tags">
                {post.data.tags.map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            </div>
            <h2 class="post-card__title">{post.data.title}</h2>
            <p class="post-card__excerpt">{post.data.description}</p>
            <span class="post-card__read">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Base>

<style>
  .blog-index {
    padding: var(--space-64) 0 var(--space-96);
    background: var(--bg);
    min-height: 100vh;
  }

  .blog-header {
    margin-bottom: var(--space-64);
    max-width: 640px;
  }

  .blog-headline {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-16) 0 var(--space-24);
    line-height: 1.1;
  }

  .blog-description {
    font-size: 18px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .posts-grid {
    display: grid;
    gap: var(--space-32);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    padding: var(--space-32);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.2s ease, transform 0.2s ease;
    text-decoration: none;
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .post-card__tags {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: var(--radius-full);
  }

  .post-card__title {
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    margin: var(--space-4) 0;
  }

  .post-card__excerpt {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
  }

  .post-card__read {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    align-self: flex-start;
    margin-top: var(--space-8);
  }

  @media (min-width: 768px) {
    .post-card__meta { flex-direction: row; }
    .posts-grid { gap: var(--space-24); }
  }
</style>