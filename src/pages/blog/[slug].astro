---
import { getCollection, type CollectionEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogCTA from '../../components/BlogCTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
};

const isoDate = post.data.pubDate.toISOString().split('T')[0];

const tagToSlug = (t: string) =>
  t.toLowerCase().replace(/&/g, 'and').replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '').replace(/-+/g, '-');

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `https://www.mkultraman.com/blog/${post.id}/`,
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  ...(post.data.heroImage ? {
    "image": {
      "@type": "ImageObject",
      "url": post.data.heroImage.startsWith('http')
        ? post.data.heroImage
        : `https://www.mkultraman.com${post.data.heroImage}`,
      "width": 1200,
      "height": 630
    }
  } : {
    "image": {
      "@type": "ImageObject",
      "url": "https://www.mkultraman.com/og-default.png",
      "width": 1200,
      "height": 630
    }
  }),
  "author": {
    "@type": "Person",
    "@id": "https://www.mkultraman.com/#person",
    "name": "Matt Ketchum",
    "alternateName": "MKUltraman",
    "url": "https://www.mkultraman.com"
  },
  "publisher": {
    "@type": "Organization",
    "@id": "https://www.mkultraman.com/#organization",
    "name": "MKUltraman",
    "url": "https://www.mkultraman.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.mkultraman.com/blog/${post.id}/`
  },
  "keywords": post.data.tags.join(', '),
  "inLanguage": "en",
  "isPartOf": {
    "@id": "https://www.mkultraman.com/#website"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.mkultraman.com/" },
    { "@type": "ListItem", "position": 2, "name": "Writing", "item": "https://www.mkultraman.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://www.mkultraman.com/blog/${post.id}/` }
  ]
};
---

<Base
  title={`${post.data.title} — MKUltraman`}
  description={post.data.description}
  article={true}
  pubDate={post.data.pubDate.toISOString()}
>
  <Nav />

  <main class="blog-post">
    <div class="container">
      <article class="post">
        <header class="post-header">
          <a href="/blog" class="back-link">← All articles</a>

          <div class="post-meta">
            <time class="post-date" datetime={isoDate}>{formatDate(post.data.pubDate)}</time>
            <div class="post-tags">
              {post.data.tags.map(tag => (
                <a href={`/blog/tag/${tagToSlug(tag)}/`} class="post-tag">{tag}</a>
              ))}
            </div>
          </div>

          <h1 class="post-title">{post.data.title}</h1>
          <p class="post-description">{post.data.description}</p>
        </header>

        <div class="post-content">
          <Content />
        </div>

        <BlogCTA tags={post.data.tags} />
      </article>
    </div>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Base>

<style>
  .blog-post {
    padding: var(--space-96) 0;
    background: var(--bg);
    min-height: 100vh;
  }

  .post {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: var(--space-64);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-32);
    display: inline-block;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--accent); }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    margin-bottom: var(--space-32);
    flex-wrap: wrap;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .post-tags {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }
  .post-tag:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: var(--space-24);
  }

  .post-description {
    font-size: 18px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-48);
  }

  .post-content {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text);
  }

  .post-content :global(h2) {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    color: var(--text);
    margin: var(--space-48) 0 var(--space-24);
    letter-spacing: -0.01em;
  }

  .post-content :global(h3) {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    margin: var(--space-32) 0 var(--space-16);
    letter-spacing: -0.01em;
  }

  .post-content :global(p) {
    margin: var(--space-24) 0;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: var(--space-24) 0;
    padding-left: var(--space-32);
  }

  .post-content :global(li) {
    margin: var(--space-12) 0;
    list-style-type: disc;
    color: var(--text-muted);
  }

  .post-content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .post-content :global(em) {
    font-style: italic;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--surface);
    color: var(--accent);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-24);
    margin: var(--space-32) 0;
    font-style: italic;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .post-meta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>