---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ToolsSchema from '../../components/ToolsSchema.astro';

const agents = [
  { name: 'Money', desc: 'Tax filing, Stripe reconciliation, expense tracking. Knows Japanese tax deadlines and 確定申告 flow.' },
  { name: 'People', desc: 'Contact resolution, networking introductions, CRM queries. Finds who you need to talk to.' },
  { name: 'Time', desc: 'Scheduling, workflow prompts, deadline tracking. Keeps your operations on cadence.' },
  { name: 'Intel', desc: 'Market research, competitor monitoring, news alerts. Structured intelligence for decisions.' },
  { name: 'Words', desc: 'Content drafting, translation review, copywriting. Bilingual output tuned for Japan.' },
  { name: 'Events', desc: 'OCR Japanese flyers, event discovery, RSVP management. Never miss a relevant gathering.' },
  { name: 'Home', desc: 'Real estate search, akiya databases, relocation logistics. Navigates Japan\'s property landscape.' },
  { name: 'Transit', desc: 'Train routing, fare calculation, transfer optimization. Faster than any transit app for complex routes.' },
  { name: 'Health', desc: 'Medical provider lookup, appointment routing, insurance navigation. Healthcare access in English.' },
  { name: 'Legal', desc: 'Intake and routing to vetted English-speaking lawyers and 行政書士. Visa, contracts, compliance.' },
  { name: 'Docs', desc: 'Document repository, retrieval, search. Your business knowledge base in one bot.' },
];

const tiers = [
  { name: 'Free', price: '$0', period: '', features: ['3 agents (Time, Transit, Intel)', 'Rate limited', 'Telegram access'] },
  { name: 'Pro', price: '$39', period: '/month', features: ['All 11 agents', 'Generous rate limits', 'Telegram + WhatsApp', 'Priority referral network'] },
  { name: 'Enterprise', price: 'Custom', period: '', features: ['Custom agent configuration', 'Dedicated referral network', 'Slack integration', 'Priority support'] },
];
---

<Base
  title="TetsuClaw — AI Work Assistant for Japan | MKUltraman Tools"
  description="11 specialist AI agents in one Telegram bot. Tax, scheduling, transit, legal, real estate — for operators in Japan."
>
  <ToolsSchema tool="tetsuno-claw" />
  <Nav />
  <main>
    <section class="product-hero">
      <div class="container">
        <a href="/tools" class="back-link">&larr; All tools</a>
        <div class="product-hero__top">
          <span class="product-hero__tag">AI work assistant</span>
          <span class="product-hero__status">Live</span>
        </div>
        <h1 class="product-hero__name">TetsuClaw</h1>
        <p class="product-hero__headline">
          A work operating system for Japan.
        </p>
        <p class="product-hero__sub">
          Running a business in Japan as a non-native speaker means hitting
          walls constantly — tax filings, legal paperwork, navigating
          bureaucracy in a language you half-understand. TetsuClaw puts
          eleven specialist AI agents in your Telegram, each tuned for a
          different part of operating in Japan.
        </p>
        <div class="product-hero__actions">
          <a href="#pricing" class="btn btn-primary product-hero__btn">See pricing &rarr;</a>
        </div>
      </div>
    </section>

    <section class="agents">
      <div class="container">
        <p class="eyebrow">Agent roster</p>
        <h2 class="agents__headline">Eleven agents. One conversation.</h2>
        <div class="agents__grid">
          {agents.map((a) => (
            <div class="agent">
              <h3 class="agent__name">{a.name}</h3>
              <p class="agent__desc">{a.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="referral">
      <div class="container">
        <div class="referral__box">
          <p class="eyebrow">Referral network</p>
          <h2 class="referral__headline">When AI isn't enough, humans step in.</h2>
          <p class="referral__body">
            TetsuClaw doesn't just answer questions — it routes you to vetted,
            English-speaking professionals in Japan. Tax accountants, lawyers,
            real estate agents, business consultants. Each referral is someone
            I've worked with personally.
          </p>
        </div>
      </div>
    </section>

    <section class="pricing" id="pricing">
      <div class="container">
        <p class="eyebrow">Pricing</p>
        <h2 class="pricing__headline">Start free. Scale when you need to.</h2>
        <div class="pricing__grid">
          {tiers.map((t) => (
            <div class="pricing-card">
              <p class="pricing-card__name">{t.name}</p>
              <div class="pricing-card__price">
                <span class="pricing-card__amount">{t.price}</span>
                {t.period && <span class="pricing-card__period">{t.period}</span>}
              </div>
              <ul class="pricing-card__features">
                {t.features.map((feat) => (
                  <li>{feat}</li>
                ))}
              </ul>
              <a href="#inquiry" class="btn btn-primary">
                {t.name === 'Enterprise' ? 'Contact us' : 'Get started'} &rarr;
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="tool-consult">
      <div class="container">
        <div class="tool-consult__box">
          <div class="tool-consult__content">
            <p class="tool-consult__heading">Running more than one business in Japan?</p>
            <p class="tool-consult__sub">
              TetsuClaw handles day-to-day ops. If your systems need a
              deeper overhaul — consolidated tools, clean workflows, real
              infrastructure — I do that too.
            </p>
          </div>
          <div class="tool-consult__actions">
            <a href="https://calendly.com/mkultraman/mkultraman-exploratory-call" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Book an exploratory call — $175 &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* ── Product hero (shared pattern) ── */
  .product-hero {
    padding: var(--space-96) 0 var(--space-64);
  }
  .back-link {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
    display: inline-block;
    margin-bottom: var(--space-32);
  }
  .back-link:hover { color: var(--text); }
  .product-hero__top {
    display: flex;
    align-items: center;
    gap: var(--space-16);
    margin-bottom: var(--space-16);
  }
  .product-hero__tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: var(--radius-full);
  }
  .product-hero__status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--success);
  }
  .product-hero__name {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--text);
    margin-bottom: var(--space-16);
  }
  .product-hero__headline {
    font-size: 20px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: var(--space-16);
  }
  .product-hero__sub {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 560px;
    margin-bottom: var(--space-32);
  }
  .product-hero__actions { display: flex; gap: var(--space-16); }
  .product-hero__btn { width: auto; }

  /* ── Agent roster ── */
  .agents {
    padding: var(--space-96) 0;
    border-top: 1px solid var(--border);
  }
  .agents__headline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-64);
  }
  .agents__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-24);
  }
  .agent {
    padding: var(--space-24);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .agent__name {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .agent__desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Referral ── */
  .referral {
    padding: 0 0 var(--space-96);
  }
  .referral__box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-48);
  }
  .referral__headline {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-16);
  }
  .referral__body {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 580px;
  }

  /* ── Pricing ── */
  .pricing {
    padding: var(--space-96) 0;
    border-top: 1px solid var(--border);
  }
  .pricing__headline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-64);
  }
  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-24);
  }
  .pricing-card {
    padding: var(--space-32);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }
  .pricing-card__name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }
  .pricing-card__amount {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }
  .pricing-card__period {
    font-size: 14px;
    color: var(--text-dim);
  }
  .pricing-card__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    flex: 1;
    padding-bottom: var(--space-8);
  }
  .pricing-card__features li {
    font-size: 14px;
    color: var(--text-muted);
    padding-left: var(--space-16);
    position: relative;
  }
  .pricing-card__features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 12px;
  }

  /* ── Consult CTA ── */
  .tool-consult {
    padding: 0 0 var(--space-96);
  }
  .tool-consult__box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-32);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-32);
  }
  .tool-consult__heading {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--space-4);
  }
  .tool-consult__sub {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.6;
    max-width: 480px;
  }
  .tool-consult__actions {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .agents__grid { grid-template-columns: 1fr; }
    .pricing__grid { grid-template-columns: 1fr; }
    .tool-consult__box {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
