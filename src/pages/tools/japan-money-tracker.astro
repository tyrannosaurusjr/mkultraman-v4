---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ToolsSchema from '../../components/ToolsSchema.astro';

const features = [
  { title: 'AI receipt parsing', desc: 'Paste OCR text from your phone camera (iOS Live Text or Google Lens) and Claude extracts dates, amounts, vendors, tax categories, and consumption tax rates.' },
  { title: 'Receipt image import', desc: 'Upload receipt photos for organized storage. Supports multi-image OCR for batch processing.' },
  { title: 'Bank statement processing', desc: 'Import bank PDFs and CSVs — Japanese and USD-denominated — with automatic transaction classification.' },
  { title: 'Multi-currency support', desc: 'JPY and USD transactions with historical exchange rate conversion. Rates fetched automatically by date.' },
  { title: 'Japanese tax categories', desc: '25 pre-configured expense and income categories specific to 確定申告: 旅費交通費, 消耗品費, 通信費, and more.' },
  { title: 'Consumption tax tracking', desc: 'Handles both 8% reduced rate and 10% standard rate for accurate deduction calculations.' },
  { title: 'Airtable sync', desc: 'One-click batch sync to Airtable for backup and spreadsheet-style access to your data.' },
  { title: 'Google Drive integration', desc: 'Upload and organize receipt photos via phone scanner mode. Files sorted into year/month folders.' },
  { title: 'Vendor rules engine', desc: 'Create rules to auto-categorize future transactions by vendor or keyword. Learns your patterns.' },
  { title: 'CSV export', desc: 'UTF-8 export with BOM for Excel compatibility. 26+ columns covering every field you need for filing.' },
  { title: 'Phone scanner mode', desc: 'Dedicated mobile UI for receipt capture — add to home screen, snap a photo, it goes straight to your Drive inbox.' },
  { title: 'Dashboard', desc: 'Income, expenses, deductible totals at a glance. Monthly bar charts and expense trends by category.' },
];
---

<Base
  title="Japan Money Tracker — Tax Filing for Freelancers & Expats | MKUltraman Tools"
  description="AI-powered receipt scanning, multi-currency expense tracking, and 確定申告-ready categories for freelancers and expats in Japan. Free."
>
  <ToolsSchema tool="japan-money-tracker" />
  <Nav />
  <main>
    <section class="product-hero">
      <div class="container">
        <a href="/tools" class="back-link">&larr; All tools</a>
        <div class="product-hero__top">
          <span class="product-hero__tag">Tax & finance</span>
          <span class="product-hero__status">Live</span>
        </div>
        <h1 class="product-hero__name">Japan Money Tracker</h1>
        <p class="product-hero__headline">
          Organize your money for Japanese tax filing.
        </p>
        <p class="product-hero__sub">
          Filing taxes in Japan as a freelancer or expat is a nightmare of
          scattered receipts, mixed currencies, and categories you can't read.
          Japan Money Tracker uses AI to parse your receipts, track your
          transactions in 確定申告-ready categories, and keep everything
          organized so filing day isn't chaos.
        </p>
        <div class="product-hero__actions">
          <a href="https://japan-tax-organizer.vercel.app" target="_blank" rel="noopener" class="btn btn-primary product-hero__btn">Open app &rarr;</a>
        </div>
        <p class="product-hero__note">Free to use. Runs in your browser. Your data stays local.</p>
      </div>
    </section>

    <section class="how-it-works">
      <div class="container">
        <p class="eyebrow">How it works</p>
        <h2 class="how-it-works__headline">Three ways in. One organized output.</h2>
        <div class="how-it-works__steps">
          <div class="step">
            <span class="step__num">01</span>
            <h3 class="step__title">Scan receipts</h3>
            <p class="step__desc">
              Point your phone camera at a receipt. Copy the text via Live Text
              or Google Lens. Paste it into the app. Claude extracts everything.
            </p>
          </div>
          <div class="step">
            <span class="step__num">02</span>
            <h3 class="step__title">Import statements</h3>
            <p class="step__desc">
              Drop bank PDFs or CSVs. The app classifies each transaction into
              the right Japanese tax category automatically.
            </p>
          </div>
          <div class="step">
            <span class="step__num">03</span>
            <h3 class="step__title">Export for filing</h3>
            <p class="step__desc">
              Download a clean CSV with every field your accountant or e-Tax
              needs. Or sync to Airtable for collaborative review.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <p class="eyebrow">Features</p>
        <h2 class="features__headline">Built for the realities of Japan.</h2>
        <div class="features__grid">
          {features.map((f) => (
            <div class="feature">
              <h3 class="feature__title">{f.title}</h3>
              <p class="feature__desc">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="privacy">
      <div class="container">
        <div class="privacy__box">
          <p class="eyebrow">Privacy</p>
          <h2 class="privacy__headline">Your financial data stays yours.</h2>
          <p class="privacy__body">
            All transaction data lives in your browser's local storage. Receipt
            text is sent to Claude for parsing (and nowhere else). No analytics,
            no tracking pixels, no backend database. You own your data completely.
          </p>
        </div>
      </div>
    </section>

    <section class="tool-consult">
      <div class="container">
        <div class="tool-consult__box">
          <div class="tool-consult__content">
            <p class="tool-consult__heading">Need more than a tracker?</p>
            <p class="tool-consult__sub">
              If your financial ops are scattered across spreadsheets, bank apps,
              and your accountant's inbox, I can build you a proper system.
              Stripe reconciliation, invoicing flows, reporting dashboards.
            </p>
          </div>
          <div class="tool-consult__actions">
            <a href="https://calendly.com/mkultraman/mkultraman-exploratory-call" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Book an exploratory call — $175 &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* ── Product hero ── */
  .product-hero {
    padding: var(--space-96) 0 var(--space-64);
  }
  .back-link {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
    display: inline-block;
    margin-bottom: var(--space-32);
  }
  .back-link:hover { color: var(--text); }
  .product-hero__top {
    display: flex;
    align-items: center;
    gap: var(--space-16);
    margin-bottom: var(--space-16);
  }
  .product-hero__tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: var(--radius-full);
  }
  .product-hero__status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--success);
  }
  .product-hero__name {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--text);
    margin-bottom: var(--space-16);
  }
  .product-hero__headline {
    font-size: 20px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: var(--space-16);
  }
  .product-hero__sub {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 560px;
    margin-bottom: var(--space-32);
  }
  .product-hero__actions { display: flex; gap: var(--space-16); }
  .product-hero__btn { width: auto; }
  .product-hero__note {
    margin-top: var(--space-16);
    font-size: 12px;
    color: var(--text-dim);
  }

  /* ── How it works ── */
  .how-it-works {
    padding: var(--space-96) 0;
    border-top: 1px solid var(--border);
  }
  .how-it-works__headline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-64);
  }
  .how-it-works__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
  }
  .step {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  .step__num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.06em;
  }
  .step__title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
  }
  .step__desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* ── Features ── */
  .features {
    padding: var(--space-96) 0;
    border-top: 1px solid var(--border);
  }
  .features__headline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-64);
  }
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
  }
  .feature {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .feature__title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .feature__desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Privacy ── */
  .privacy {
    padding: var(--space-96) 0;
    border-top: 1px solid var(--border);
  }
  .privacy__box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-48);
    max-width: 620px;
  }
  .privacy__headline {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-16);
  }
  .privacy__body {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── Consult CTA ── */
  .tool-consult {
    padding: 0 0 var(--space-96);
  }
  .tool-consult__box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-32);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-32);
  }
  .tool-consult__heading {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--space-4);
  }
  .tool-consult__sub {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.6;
    max-width: 480px;
  }
  .tool-consult__actions {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .how-it-works__steps { grid-template-columns: 1fr; }
    .features__grid { grid-template-columns: 1fr; }
    .tool-consult__box {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
