---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ToolsSchema from '../../components/ToolsSchema.astro';

const integrations = [
  { name: 'Stripe', desc: 'Pull customer and subscription data directly from your Stripe account.' },
  { name: 'Luma', desc: 'Import event attendees and RSVPs. Match against existing contacts.' },
  { name: 'Mailchimp', desc: 'Sync subscriber lists and tags. Deduplicate across audiences.' },
  { name: 'Google Sheets', desc: 'Import from spreadsheets — the universal glue for messy member data.' },
  { name: 'Apple Contacts', desc: 'Export and import your personal contact book for reconciliation.' },
  { name: 'Substack', desc: 'Pull subscriber lists and match against your canonical member database.' },
];

const features = [
  { title: 'Contact rectification', desc: 'Fuzzy matching across platforms finds duplicates even when names are misspelled or emails differ.' },
  { title: 'Canonical profiles', desc: 'One record per person, regardless of how many platforms they exist on. You decide which data wins.' },
  { title: 'Review queue', desc: 'Ambiguous matches surface in a review queue. You make the call, the system learns.' },
  { title: 'Import workspace', desc: 'CSV import with per-run failure inspection. See exactly what broke and why.' },
  { title: 'Bi-directional sync', desc: 'Push corrected data back to source platforms. Stripe, Mailchimp, and Luma stay in sync.' },
  { title: 'Operator dashboard', desc: 'See your total membership count, platform coverage, and data health at a glance.' },
];
---

<Base
  title="Hitoe — Membership Management | MKUltraman Tools"
  description="Normalize members and contacts across Stripe, Luma, Mailchimp, and more. One canonical list of your people."
>
  <ToolsSchema tool="hitoe" />
  <Nav />
  <main>
    <section class="product-hero">
      <div class="container">
        <a href="/tools" class="back-link">&larr; All tools</a>
        <div class="product-hero__top">
          <span class="product-hero__tag">Membership management</span>
          <span class="product-hero__status product-hero__status--soon">Coming soon</span>
        </div>
        <h1 class="product-hero__name">Hitoe</h1>
        <p class="product-hero__headline">
          One canonical list of your people.
        </p>
        <p class="product-hero__sub">
          Your members exist in Stripe, Luma, Mailchimp, Google Sheets, your
          inbox, and probably a notebook somewhere. You don't know who's
          actually in your community because nobody is the same person across
          platforms. Hitoe fixes that.
        </p>
        <div class="product-hero__actions">
          <a href="#waitlist" class="btn btn-primary product-hero__btn">Join the waitlist &rarr;</a>
        </div>
      </div>
    </section>

    <section class="integrations">
      <div class="container">
        <p class="eyebrow">Integrations</p>
        <h2 class="integrations__headline">Connects where your members already live.</h2>
        <div class="integrations__grid">
          {integrations.map((i) => (
            <div class="integration">
              <h3 class="integration__name">{i.name}</h3>
              <p class="integration__desc">{i.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <p class="eyebrow">How it works</p>
        <h2 class="features__headline">Rectify. Normalize. Sync.</h2>
        <div class="features__grid">
          {features.map((f) => (
            <div class="feature">
              <h3 class="feature__title">{f.title}</h3>
              <p class="feature__desc">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="waitlist" id="waitlist">
      <div class="container">
        <div class="waitlist__box">
          <p class="eyebrow">Early access</p>
          <h2 class="waitlist__headline">Get notified when Hitoe launches.</h2>
          <p class="waitlist__body">
            Hitoe is in active development. If you run a membership organization
            and your contact data is a mess, you're exactly who this is for.
          </p>
          <form
            name="hitoe-waitlist"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="waitlist__form"
          >
            <input type="hidden" name="form-name" value="hitoe-waitlist" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
            <div class="waitlist__fields">
              <input
                class="input"
                type="email"
                name="email"
                placeholder="you@company.co.jp"
                required
              />
              <button type="submit" class="btn btn-primary waitlist__btn">
                Notify me &rarr;
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  /* ── Product hero ── */
  .product-hero {
    padding: var(--space-96) 0 var(--space-64);
  }
  .back-link {
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.15s;
    display: inline-block;
    margin-bottom: var(--space-32);
  }
  .back-link:hover { color: var(--text); }
  .product-hero__top {
    display: flex;
    align-items: center;
    gap: var(--space-16);
    margin-bottom: var(--space-16);
  }
  .product-hero__tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: var(--radius-full);
  }
  .product-hero__status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #4ade80;
  }
  .product-hero__status--soon {
    color: var(--text-dim);
  }
  .product-hero__name {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--text);
    margin-bottom: var(--space-16);
  }
  .product-hero__headline {
    font-size: 20px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: var(--space-16);
  }
  .product-hero__sub {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 560px;
    margin-bottom: var(--space-32);
  }
  .product-hero__actions { display: flex; gap: var(--space-16); }
  .product-hero__btn { width: auto; }

  /* ── Integrations ── */
  .integrations {
    padding: var(--space-96) 0;
    border-top: 1px solid var(--border);
  }
  .integrations__headline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-64);
  }
  .integrations__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-24);
  }
  .integration {
    padding: var(--space-24);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .integration__name {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .integration__desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Features ── */
  .features {
    padding: var(--space-96) 0;
    border-top: 1px solid var(--border);
  }
  .features__headline {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-64);
  }
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-32);
  }
  .feature {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .feature__title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .feature__desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Waitlist ── */
  .waitlist {
    padding: var(--space-96) 0;
    border-top: 1px solid var(--border);
  }
  .waitlist__box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-48);
    max-width: 580px;
  }
  .waitlist__headline {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: var(--space-24) 0 var(--space-16);
  }
  .waitlist__body {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-32);
  }
  .waitlist__fields {
    display: flex;
    gap: var(--space-12);
  }
  .waitlist__fields .input {
    flex: 1;
  }
  .waitlist__btn {
    width: auto;
    flex-shrink: 0;
  }
  .hidden { display: none; }

  @media (max-width: 768px) {
    .integrations__grid { grid-template-columns: 1fr; }
    .features__grid { grid-template-columns: 1fr; }
    .waitlist__fields { flex-direction: column; }
    .waitlist__btn { width: 100%; }
  }
</style>
